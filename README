export PATH=~/Your_Toolchain_PATH/
for example /alps/prebuilt/linux-x86/toolchain/arm-linux-androideabi-4.4.x/bin
Build Command:
uboot
=====
1.TARGET_PRODUCT=lenovo75_cu_ics make lenovo75_cu_ics_confg
2.TARGET_PRODUCT=lenovo75_cu_ics make lenovo75_cu_ics
kernel
======
cd kernel directory
TARGET_PRODUCT=lenovo75_cu_ics MTK_ROOT_CUSTOM=../mediatek/custom/ make

